# Base URL API quotation
API_BASE_URL=https://dev-api-quotation.motorsights.com/api/quotation

# SSO Auth — untuk generate Bearer token otomatis
AUTH_URL=https://dev-gateway.motorsights.com/api/auth/sso/login
AUTH_EMAIL=abdulharris@motorsights.net
AUTH_PASSWORD=your_password_here

# Timeout request dalam ms (opsional, default 30000)
API_TIMEOUT_MS=30000

# ---- HTTP MCP Server ----
MCP_HTTP_PORT=9533

# OAuth guard untuk endpoint /mcp
# Set true untuk aktifkan validasi client_id + client_secret
# Set false untuk skip validasi (development/testing)
OAUTH_ENABLED=true
OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here
