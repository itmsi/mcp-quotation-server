# Base URL API quotation
API_BASE_URL=https://dev-api-quotation.motorsights.com/api/quotation

# SSO Auth — untuk generate Bearer token otomatis
AUTH_URL=https://dev-gateway.motorsights.com/api/auth/sso/login
