# Base URL API kamu (JANGAN pakai trailing slash ganda)
# Dev:
API_BASE_URL=https://dev-api-quotation.motorsights.com/api/quotation
# Atau gateway production:
# API_BASE_URL=https://gateway.motorsights.com/api/quotation

# Bearer/JWT token untuk otentikasi ke API
API_TOKEN=isi_token_jwt_kamu_disini

# Timeout request dalam ms (opsional, default 30000)
API_TIMEOUT_MS=30000

# ---- Hanya dipakai kalau jalan via `npm run start:http` ----
# Port HTTP server MCP (bukan port API backend)
MCP_HTTP_PORT=9533
# Token untuk membatasi akses ke endpoint MCP ini dari network.
# WAJIB diisi kalau server ini bisa diakses dari luar (lewat internet/VPN).
# Client (Claude) harus kirim header: Authorization: Bearer <MCP_HTTP_TOKEN>
MCP_HTTP_TOKEN=generate_token_acak_yang_kuat_disini
