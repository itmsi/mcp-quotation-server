# Timeout request dalam ms (opsional, default 30000)
API_TIMEOUT_MS=30000

# ---- Hanya dipakai kalau jalan via `npm run start:http` ----
MCP_HTTP_PORT=9533
MCP_HTTP_TOKEN=generate_token_acak_yang_kuat_disini
